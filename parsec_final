import httpx
from lxml import etree
from typing import Optional
import textwrap


def _envelope(method, body_inner):
    """Оборачивает тело запроса в SOAP-конверт."""
    tmpl = (
        '<?xml version="1.0" encoding="utf-8"?>\n'
        '<soap:Envelope\n'
        '    xmlns:soap="{soap}"\n'
        '    xmlns:xsi="{xsi}"\n'
        '    xmlns:xsd="{xsd}">\n'
        '  <soap:Body>\n'
        '    <{method} xmlns="{parsec}">\n'
        '{body}'
        '    </{method}>\n'
        '  </soap:Body>\n'
        '</soap:Envelope>'
    )
    return tmpl.format(
        soap=NS_SOAP,
        xsi=NS_XSI,
        xsd=NS_XSD,
        parsec=NS_PARSEC,
        method=method,
        body=textwrap.indent(body_inner.strip(), "      ") + "\n",
    ).encode("utf-8")


def _parse_body(response_bytes):
    """Парсит SOAP-ответ, возвращает элемент Body."""
    root = etree.fromstring(response_bytes)
    body = root.find("{" + NS_SOAP + "}Body")
    if body is None:
        raise ValueError("SOAP Body не найден")
    fault = body.find("{" + NS_SOAP + "}Fault")
    if fault is not None:
        fcode = _text(fault, "faultcode") or ""
        fstr  = _text(fault, "faultstring") or ""
        raise RuntimeError("SOAP Fault [" + fcode + "]: " + fstr)
    return body


def _text(node, local_name, default=None):
    """Первый дочерний элемент с данным локальным именем -> .text."""
    for child in node:
        if etree.QName(child.tag).localname == local_name:
            t = child.text or ""
            return t.strip() or default
    return default


def _child(node, *local_names):
    """Последовательный поиск вглубь по локальным именам."""
    cur = node
    for name in local_names:
        found = None
        for ch in cur:
            if etree.QName(ch.tag).localname == name:
                found = ch
                break
        if found is None:
            return None
        cur = found
    return cur


def _children(node, local_name):
    """Все прямые дочерние элементы с данным локальным именем."""
    return [ch for ch in node if etree.QName(ch.tag).localname == local_name]


def _all_tags(node):
    """Словарь localname -> element по всему дереву (для отладки)."""
    return {etree.QName(el.tag).localname: el for el in node.iter()}


class ParsecClient(object):
    """
    SOAP-клиент для Parsec Integration Service.
    Использование:
        with ParsecClient(CONNECTION) as c:
            resp = c.call("GetOrgUnitsHierarhy")
    """

    def __init__(self, config):
        self.config     = config
        self.base_url   = (
            "http://" + config["host_addr"] +
            ":10101/IntegrationService/IntegrationService.asmx"
        )
        self._http      = None
        self.session_id = None

    def _post(self, method, body_xml):
        payload = _envelope(method, body_xml)
        headers = {
            "Content-Type": "text/xml; charset=utf-8",
            "SOAPAction":   '"' + NS_PARSEC + "/" + method + '"',
        }
        resp = self._http.post(self.base_url, content=payload, headers=headers)
        resp.raise_for_status()
        return _parse_body(resp.content)

    def connect(self):
        self._http = httpx.Client(timeout=self.config.get("timeout", 30))
        body = (
            "<domain>" + self.config["organization"] + "</domain>\n" +
            "<userName>" + self.config["username"] + "</userName>\n" +
            "<password>" + self.config["password"] + "</password>"
        )
        body_el = self._post("OpenSession", body)
        result  = _child(body_el, "OpenSessionResponse", "OpenSessionResult")
        if result is None:
            raise RuntimeError("OpenSession: неожиданная структура ответа")
        code = _text(result, "Result")
        if code == "-1":
            raise ConnectionError("Авторизация: " + (_text(result, "ErrorMessage") or ""))
        session_node    = _child(result, "Value")
        self.session_id = _text(session_node, "SessionID")
        print("Сессия открыта. SessionID: " + str(self.session_id))
        return self

    def disconnect(self):
        if self.session_id and self._http:
            try:
                self._post("CloseSession",
                           "<sessionID>" + self.session_id + "</sessionID>")
                print("Сессия закрыта.")
            except Exception as e:
                print("Предупреждение при закрытии сессии: " + str(e))
        if self._http:
            self._http.close()
        self.session_id = None
        self._http      = None

    def __enter__(self):
        return self.connect()

    def __exit__(self, *_):
        self.disconnect()

    def call(self, method, extra_xml=""):
        """Вызывает метод, автоматически подставляя sessionID."""
        body = "<sessionID>" + self.session_id + "</sessionID>\n" + extra_xml
        body_el  = self._post(method, body)
        response = _child(body_el, method + "Response")
        return response


print("ParsecClient определён.")


