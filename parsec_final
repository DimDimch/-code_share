import time


def _dt_soap(dt):
    """datetime (UTC) -> строка 'yyyy-mm-ddThh:mm:ssZ'."""
    utc = dt.astimezone(timezone.utc)
    return utc.strftime("%Y-%m-%dT%H:%M:%SZ")


def _build_params_xml(date_from, date_to, transaction_types, max_result_size,
                       territory_ids=None, org_ids=None, person_ids=None):
    tt_xml = "\n".join(
        "    <unsignedInt>" + str(t) + "</unsignedInt>"
        for t in transaction_types
    )
    parts = [
        "<parameters>",
        "  <StartDate>" + _dt_soap(date_from) + "</StartDate>",
        "  <EndDate>"   + _dt_soap(date_to)   + "</EndDate>",
        "  <TransactionTypes>",
        tt_xml,
        "  </TransactionTypes>",
        "  <MaxResultSize>" + str(max_result_size) + "</MaxResultSize>",
    ]
    if territory_ids:
        parts.append("  <Territories>")
        for g in territory_ids:
            parts.append("    <guid>" + g + "</guid>")
        parts.append("  </Territories>")
    if org_ids:
        parts.append("  <Organizations>")
        for g in org_ids:
            parts.append("    <guid>" + g + "</guid>")
        parts.append("  </Organizations>")
    if person_ids:
        parts.append("  <Users>")
        for g in person_ids:
            parts.append("    <guid>" + g + "</guid>")
        parts.append("  </Users>")
    parts.append("</parameters>")
    return "\n".join(parts)


def _build_fields_xml(field_guids):
    items = "\n".join("  <guid>" + g + "</guid>" for g in field_guids)
    return "<fields>\n" + items + "\n</fields>"


def fetch_event_history(c,
                         date_from,
                         date_to,
                         transaction_types=None,
                         field_guids=None,
                         field_columns=None,
                         max_result_size=MAX_RESULT_SIZE,
                         chunk_size=CHUNK_SIZE,
                         territory_ids=None,
                         org_ids=None,
                         person_ids=None):

    if transaction_types is None:
        transaction_types = TRANSACTION_TYPES
    if field_guids is None:
        field_guids = FIELD_GUIDS
    if field_columns is None:
        field_columns = FIELD_COLUMNS

    # 1. Открываем сессию истории
    print("Открытие сессии истории событий...")
    params_xml = _build_params_xml(
        date_from, date_to, transaction_types, max_result_size,
        territory_ids, org_ids, person_ids
    )
    resp    = c.call("OpenEventHistorySession", params_xml)
    hist_id = _guid_result(resp, "OpenEventHistorySession")
    print("  eventHistorySessionID: " + str(hist_id))

    try:
        # 2. Кол-во событий
        extra = "<eventHistorySessionID>" + hist_id + "</eventHistorySessionID>"
        resp  = c.call("GetEventHistoryResultCount", extra)
        count_el = _child(resp, "GetEventHistoryResultCountResult")
        total = int(count_el.text) if (count_el is not None and count_el.text) else 0
        print("  Всего событий: " + str(total))

        if total == 0:
            return pd.DataFrame(columns=field_columns)

        # 3. Постраничная выгрузка
        fields_xml = _build_fields_xml(field_guids)
        all_rows   = []
        t0 = time.time()

        for offset in range(0, total, chunk_size):
            n = min(chunk_size, total - offset)
            extra = (
                "<eventHistorySessionID>" + hist_id + "</eventHistorySessionID>\n" +
                fields_xml + "\n" +
                "<offset>" + str(offset) + "</offset>\n" +
                "<count>"  + str(n)      + "</count>"
            )
            resp = c.call("GetEventHistoryResult", extra)
            rows = parse_event_objects(resp, field_columns)
            all_rows.extend(rows)

            done    = offset + n
            elapsed = time.time() - t0
            speed   = done / elapsed if elapsed > 0 else 0
            eta     = (total - done) / speed if speed > 0 else 0
            pct     = done * 100.0 / total
            print(
                "\r  " + str(round(pct, 1)) + "%"
                "  " + str(done) + "/" + str(total) +
                "  " + str(int(speed)) + " зап/с" +
                "  ETA " + str(int(eta)) + "с   ",
                end=""
            )

        print("\n  Готово за " + str(round(time.time() - t0, 1)) + "с")

    finally:
        # 4. Закрываем сессию истории — ВСЕГДА
        try:
            extra = "<eventHistorySessionID>" + hist_id + "</eventHistorySessionID>"
            c._post(
                "CloseEventHistorySession",
                "<sessionID>" + c.session_id + "</sessionID>\n" + extra
            )
            print("  Сессия истории закрыта.")
        except Exception as e:
            print("  Предупреждение CloseEventHistorySession: " + str(e))

    df = pd.DataFrame(all_rows, columns=field_columns)
    print("  DataFrame: " + str(df.shape[0]) + " строк x " + str(df.shape[1]) + " столбцов")
    return df


print("fetch_event_history определена.")


