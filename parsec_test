# ## 1. Запрос событий — выбери нужные поля
# Укажи имена полей из ALL_EVENT_FIELDS выше.

# %%
# ── НАСТРОЙ ЗДЕСЬ ─────────────────────────────────────────────────────────────
HOURS_BACK = 24

MY_FIELDS = [
    "event_datetime",
    "transaction_code_10",
    "transaction_name",
    "person_fullname",
    "person_lastname",
    "person_firstname",
    "tab_number",
    "department",
    "territory_name",
    "zone_name",
    "card_code",
    "person_id",
]

# Дополнительные фильтры (None = без фильтра)
FILTER_PERSON_ID    = None   # "guid-..."
FILTER_TERRITORY_ID = None   # "guid-..."
MAX_EVENTS          = 5000
# ──────────────────────────────────────────────────────────────────────────────

# Строим список GUID-ов в нужном порядке
field_guids = []
field_names = []
for name in MY_FIELDS:
    if name in ALL_EVENT_FIELDS:
        field_guids.append(ALL_EVENT_FIELDS[name])
        field_names.append(name)
    else:
        print("⚠ Неизвестное поле: " + name)

fields_xml = "<fields>" + "".join("<guid>" + g + "</guid>" for g in field_guids) + "</fields>"

date_to   = datetime.now(timezone.utc)
date_from = date_to - timedelta(hours=HOURS_BACK)

params = (
    "<parameters>"
    + "<StartDate>" + _dt(date_from) + "</StartDate>"
    + "<EndDate>"   + _dt(date_to)   + "</EndDate>"
    + "<MaxResultSize>" + str(MAX_EVENTS) + "</MaxResultSize>"
    + ("" if not FILTER_PERSON_ID    else "<Users><guid>"       + FILTER_PERSON_ID    + "</guid></Users>")
    + ("" if not FILTER_TERRITORY_ID else "<Territories><guid>" + FILTER_TERRITORY_ID + "</guid></Territories>")
    + "</parameters>"
)

root = _post("OpenEventHistorySession", "<sessionID>" + _sid() + "</sessionID>" + params)
hist_id = _find(root, "Value")

if not hist_id:
    print("✗ " + str(_find(root, "ErrorMessage")))
else:
    root2 = _post("GetEventHistoryResultCount",
        "<sessionID>" + _sid() + "</sessionID>"
        + "<eventHistorySessionID>" + hist_id + "</eventHistorySessionID>")
    total = int(_find(root2, "GetEventHistoryResultCountResult") or "0")
    print("Всего событий: " + str(total) + " | запрашиваем: " + str(min(total, MAX_EVENTS)))

    rows = []
    chunk = 500
    for offset in range(0, min(total, MAX_EVENTS), chunk):
        n    = min(chunk, min(total, MAX_EVENTS) - offset)
        root3 = _post("GetEventHistoryResult",
            "<sessionID>" + _sid() + "</sessionID>"
            + "<eventHistorySessionID>" + hist_id + "</eventHistorySessionID>"
            + fields_xml
            + "<offset>" + str(offset) + "</offset>"
            + "<count>"  + str(n)      + "</count>")
        for ev in _findall(root3, "EventObject"):
            vals = [ch.text for ch in ev.iter() if _lname(ch) == "anyType"]
            while len(vals) < len(field_names):
                vals.append(None)
            rows.append(vals[:len(field_names)])

    _post("CloseEventHistorySession",
        "<sessionID>" + _sid() + "</sessionID>"
        + "<eventHistorySessionID>" + hist_id + "</eventHistorySessionID>")

    df_events = pd.DataFrame(rows, columns=field_names)

    # Приводим datetime
    if "event_datetime" in df_events.columns:
        df_events["event_datetime"] = pd.to_datetime(df_events["event_datetime"], utc=True, errors="coerce")

    if "transaction_code_10" in df_events.columns:
        df_events["transaction_code_10"] = pd.to_numeric(df_events["transaction_code_10"], errors="coerce")

    print("DataFrame: " + str(df_events.shape[0]) + " строк x " + str(df_events.shape[1]) + " столбцов")
    df_events


