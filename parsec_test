# %%
root = _post("GetTransactionTypes",
    "<sessionID>" + _sid() + "</sessionID>"
    + "<classMask>-1</classMask>")

rows = []
for t in _findall(root, "TransactionType"):
    rows.append({
        "id":         _find(t, "ID"),
        "name":       _find(t, "NAME"),
        "class_mask": _find(t, "CLASS_MASK"),
    })

df_ttypes = pd.DataFrame(rows)
if not df_ttypes.empty:
    df_ttypes["id"] = pd.to_numeric(df_ttypes["id"], errors="coerce")
    df_ttypes = df_ttypes.sort_values("id").reset_index(drop=True)

print("Типов транзакций: " + str(len(df_ttypes)))
df_ttypes


