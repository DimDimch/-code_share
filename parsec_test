import httpx
from lxml import etree
import pandas as pd
from datetime import datetime, timezone, timedelta

HOST     = "192.168.1.50"
DOMAIN   = "SYSTEM"
USERNAME = "parsec"
PASSWORD = "parsec"

BASE_URL  = "http://" + HOST + ":10101/IntegrationService/IntegrationService.asmx"
NS_PARSEC = "http://parsec.ru/Parsec3IntergationService"
NS_SOAP   = "http://schemas.xmlsoap.org/soap/envelope/"

pd.set_option("display.max_columns",  None)
pd.set_option("display.max_rows",     100)
pd.set_option("display.width",        200)
pd.set_option("display.max_colwidth", 60)

# ── transport ─────────────────────────────────────────────────────────────────

_HTTP = httpx.Client(timeout=60)

def _post(method, body):
    xml = (
        '<?xml version="1.0" encoding="utf-8"?>'
        + '<soap:Envelope xmlns:soap="' + NS_SOAP + '"'
        + ' xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"'
        + ' xmlns:xsd="http://www.w3.org/2001/XMLSchema">'
        + '<soap:Body>'
        + '<' + method + ' xmlns="' + NS_PARSEC + '">'
        + body.strip()
        + '</' + method + '>'
        + '</soap:Body></soap:Envelope>'
    ).encode("utf-8")
    resp = _HTTP.post(BASE_URL, content=xml, headers={
        "Content-Type": "text/xml; charset=utf-8",
        "SOAPAction": '"' + NS_PARSEC + "/" + method + '"',
    })
    resp.raise_for_status()
    return etree.fromstring(resp.content)

def _sid():
    return SESSION_ID

def _lname(node):
    return etree.QName(node.tag).localname

def _find(node, tag):
    for ch in node.iter():
        if _lname(ch) == tag:
            return (ch.text or "").strip()
    return None

def _findall(node, tag):
    return [ch for ch in node.iter() if _lname(ch) == tag]

def _dt(dt):
    return dt.astimezone(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

# ── открыть сессию ────────────────────────────────────────────────────────────

root = _post("OpenSession",
    "<domain>"    + DOMAIN   + "</domain>"
    + "<userName>" + USERNAME + "</userName>"
    + "<password>" + PASSWORD + "</password>"
)
SESSION_ID = _find(root, "SessionID")
if SESSION_ID:
    print("✓ Сессия: " + SESSION_ID)
else:
    print("✗ " + str(_find(root, "ErrorMessage")))


