# ## 2. Все сотрудники — максимум полей

# %%
# GetOrgUnitsHierarhyWithPersons — дерево подразделений + все сотрудники одним запросом
# Дополнительно: GetPersonIdentifiers — карты каждого сотрудника

root = _post("GetOrgUnitsHierarhyWithPersons",
    "<sessionID>" + _sid() + "</sessionID>")

result_el = None
for ch in root.iter():
    if _lname(ch) == "GetOrgUnitsHierarhyWithPersonsResult":
        result_el = ch
        break

persons  = []
org_map  = {}  # id -> name для быстрого lookup

if result_el is not None:
    for obj in result_el:
        tab = _find(obj, "TAB_NUM")
        oid = _find(obj, "ID")
        nm  = _find(obj, "NAME")

        if tab is None:
            # Это OrgUnit — сохраняем в map
            if oid and nm:
                org_map[oid] = nm
            continue

        # Это Person
        persons.append({
            "person_id":   oid,
            "last_name":   _find(obj, "LAST_NAME"),
            "first_name":  _find(obj, "FIRST_NAME"),
            "middle_name": _find(obj, "MIDDLE_NAME"),
            "tab_number":  tab,
            "org_id":      _find(obj, "ORG_ID"),
        })

print("Сотрудников: " + str(len(persons)) + " | Подразделений: " + str(len(org_map)))

df_persons = pd.DataFrame(persons)

# Добавляем название подразделения
if not df_persons.empty and org_map:
    df_persons["department"] = df_persons["org_id"].map(org_map)

# Добавляем коды карт (GetPersonIdentifiers для каждого)
# Внимание: если сотрудников много — займёт время. Убери блок если не нужно.
LOAD_IDENTIFIERS = True   # False = пропустить

if LOAD_IDENTIFIERS and not df_persons.empty:
    print("Загружаем карты... (может занять время)")
    card_rows = []
    for pid in df_persons["person_id"].dropna():
        try:
            root_id = _post("GetPersonIdentifiers",
                "<sessionID>" + _sid() + "</sessionID>"
                + "<personID>" + pid + "</personID>")
            for idf in _findall(root_id, "Identifier"):
                card_rows.append({
                    "person_id":  pid,
                    "card_code":  _find(idf, "CODE"),
                    "is_primary": _find(idf, "IS_PRIMARY"),
                    "acc_group":  _find(idf, "ACCGROUP_ID"),
                })
        except Exception:
            pass

    if card_rows:
        df_cards = pd.DataFrame(card_rows)
        # Основная карта
        primary = df_cards[df_cards["is_primary"] == "true"][["person_id","card_code"]]
        primary = primary.rename(columns={"card_code": "primary_card"})
        # Все карты через запятую
        all_cards = (
            df_cards.groupby("person_id")["card_code"]
            .apply(lambda x: ", ".join(filter(None, x)))
            .reset_index()
            .rename(columns={"card_code": "all_cards"})
        )
        df_persons = df_persons.merge(primary,   on="person_id", how="left")
        df_persons = df_persons.merge(all_cards, on="person_id", how="left")
        print("Карт загружено: " + str(len(df_cards)))

print("df_persons: " + str(df_persons.shape[0]) + " строк x " + str(df_persons.shape[1]) + " столбцов")
df_persons


# %% [markdown]
# ---
# ## 3. Все территории — максимум полей

# %%
# GetTerritoriesHierarhy возвращает TerritoryWithComponent — максимум доступных полей:
# ID, TYPE, NAME, DESC, PARENT_ID, COMPONENT_ID, FEATURE_MASK

root = _post("GetTerritoriesHierarhy",
    "<sessionID>" + _sid() + "</sessionID>")

# Находим массив результатов
result_el = None
for ch in root.iter():
    if _lname(ch) == "GetTerritoriesHierarhyResult":
        result_el = ch
        break

TERRITORY_TYPES = {
    "0": "Папка",
    "1": "Дверь",
    "2": "Участок",
    "3": "Другое",
}

# FEATURE_MASK — расшифровка битов
FEATURE_BITS = {
    0:  "Дверь",
    1:  "2 считывателя",
    2:  "APB",
    3:  "Сложные расписания",
    4:  "Настольный считыватель",
    5:  "Охранная зона",
    6:  "Источник видео",
    7:  "Турникет",
    9:  "Расписания не поддерж.",
    10: "Программный контроллер",
    12: "Без ограничений лицензии",
    13: "Лифтовой контроллер",
    62: "Отключён оператором",
    63: "Нет лицензии",
}

def decode_feature_mask(mask_str):
    if not mask_str:
        return ""
    try:
        mask = int(mask_str)
    except Exception:
        return mask_str
    features = []
    for bit, name in FEATURE_BITS.items():
        if mask & (1 << bit):
            features.append(name)
    return ", ".join(features) if features else str(mask)

rows = []
if result_el is not None:
    for t in result_el:
        tid    = _find(t, "ID")
        ttype  = _find(t, "TYPE")
        tname  = _find(t, "NAME")
        tdesc  = _find(t, "DESC")
        parent = _find(t, "PARENT_ID")
        comp   = _find(t, "COMPONENT_ID")
        fmask  = _find(t, "FEATURE_MASK")

        rows.append({
            "id":              tid,
            "type_code":       ttype,
            "type_name":       TERRITORY_TYPES.get(str(ttype), str(ttype)),
            "name":            tname,
            "desc":            tdesc,
            "parent_id":       parent,
            "component_id":    comp,
            "feature_mask_raw": fmask,
            "features":        decode_feature_mask(fmask),
        })

df_terr = pd.DataFrame(rows)

# Добавляем имя родителя для читаемости иерархии
if not df_terr.empty:
    id_to_name = df_terr.set_index("id")["name"].to_dict()
    df_terr["parent_name"] = df_terr["parent_id"].map(id_to_name)

    # Полный путь (parent_name / name)
    df_terr["full_path"] = df_terr.apply(
        lambda r: (str(r["parent_name"]) + " / " + str(r["name"]))
        if r["parent_name"] else str(r["name"]),
        axis=1
    )

print("Территорий: " + str(len(df_terr)))
print("Типы:")
print(df_terr["type_name"].value_counts().to_string())
print()
df_terr


